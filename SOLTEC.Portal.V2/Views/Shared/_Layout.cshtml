    <style>
        /* Marca de agua */
        .watermark {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/_simiPet.jpg');
            background-repeat: no-repeat;
            background-size: cover!important;
            background-position: center!important;
            opacity: 0.25;
            z-index: 0;
            pointer-events: none;
        }

        /* Asegura que contenido principal, header, footer y sidebar estén por encima */
      /*   .contentPrincipal,
        header,
        footer,
        .sidenav-fixed {
            position: relative;
            z-index: 1;
        } */


        .contentPrincipal {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 90px); /* Header (50px) + Footer (40px) */
    padding: 20px;
    box-sizing: border-box;
}

/* Contenedor de logs o cualquier contenido que deba llenar el main */
#logContainer, .fullHeightScroll {
    flex: 1;                 /* Ocupa todo el espacio restante del main */
    overflow-y: auto;        /* Scroll vertical */
    background-color: #1e1e1e;
    color: #ffffff;
    padding: 10px;
    font-family: monospace;
    white-space: pre-wrap;   /* Mantiene saltos de línea */
    box-sizing: border-box;
    border-radius: 4px;
}

        body {
            display: flex;
            min-height: 100vh;
            margin: 0;
        }

        /* Sidebar lateral fijo */
        .sidenav-fixed {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background-color: #343A40;
        }

        /* Header */
        header {
            border-left: 1px solid #ccc;
            position: fixed;
            top: 0;
            left: 250px;
            right: 0;
            height: 50px;
            z-index: 1000;
            background-color: #343A40;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 20px;
            color: white;
            border-bottom: none;
            box-sizing: border-box;
        }

            header .divider-vertical {
                background-color: rgba(255,255,255,0.3);
            }

            header span {
                font-weight: 500;
                color: white;
            }

        /* Contenido principal */
        main {
            flex: 1;
            margin-left: 250px;
            margin-top: 50px;
            margin-bottom: 40px;
            padding: 20px;
        }

        /* Footer */
        footer {
            position: fixed;
            bottom: 0;
            left: 250px;
            right: 0;
            height: 40px;
            background-color: #f2f2f2;
            text-align: center;
            line-height: 40px;
            z-index: 1000;
        }

        /* Botón logout */
        .logout-btn {
            display: flex;
            align-items: center;
            gap: 4px;
            color: white;
            text-transform: none;
        }

            .logout-btn i {
                color: #ff6b6b;
                line-height: 1;
                margin-right: 4px;
            }

        /* Colores de menús */
        .menu-seguridad .collapsible-header,
        .menu-administracion .collapsible-header {
            color: white;
        }

        .collapsible-header i {
            margin-right: 10px;
        }

        /* Responsive */
        @@media only screen and (max-width: 992px) {
            main

        {
            margin-left: 0;
            margin-top: 60px;
            margin-bottom: 40px;
        }

        header {
            left: 0;
        }

        footer {
            left: 0;
        }

        .sidenav-fixed {
            display: none;
        }

        .sidenav-trigger-btn {
            display: block !important;
        }

        }

        .sidenav-trigger-btn {
            display: none;
        }

        /* Overlay de carga */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(250, 250, 250, 0.88);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 5000;
            text-align: center;
        }

        .mascota-loading {
            width: 160px;
            height: auto;
            margin-bottom: 20px;
            animation: bounce 1.8s infinite ease-in-out;
        }

        .preloader-wrapper {
            margin-top: 10px;
            margin-bottom: 20px;
        }
    </style>
</head>
