    <script src="~/js/site.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var collapsibles = document.querySelectorAll('.collapsible');
            M.Collapsible.init(collapsibles, { accordion: false });

            document.querySelectorAll('.collapsible-body a').forEach(function (link) {
                link.addEventListener('click', function (e) { e.stopPropagation(); });
            });

            var sidenavs = document.querySelectorAll('.sidenav');
            M.Sidenav.init(sidenavs);

            document.addEventListener('click', function (e) {
                var mobileSidenav = document.querySelector('#mobile-demo');
                var instance = M.Sidenav.getInstance(mobileSidenav);
                if (instance && instance.isOpen && !mobileSidenav.contains(e.target) && !e.target.classList.contains('sidenav-trigger') && !e.target.closest('.sidenav-trigger')) {
                    instance.close();
                }
            });
        });

        // Sesión
        document.addEventListener('DOMContentLoaded', function () {
            const modalElems = document.querySelectorAll('.modal');
            M.Modal.init(modalElems, { dismissible: false });

            const modalElem = document.getElementById('session-modal');
            const modalInstance = M.Modal.getInstance(modalElem);

            const sessionTimeOut = @ViewBag.SessionMinutes * 60 * 1000;
            const warningTime = 1 * 60 * 1000;
            let countdownTimer, warningTimer, logoutTimer;
            let remainingSeconds;

            function formatTime(seconds) {
                const min = Math.floor(seconds / 60).toString().padStart(2, '0');
                const sec = (seconds % 60).toString().padStart(2, '0');
                return `${min}:${sec}`;
            }

            function startCountdown(seconds) {
                const countdownElem = document.getElementById('session-countdown');
                remainingSeconds = seconds;
                countdownElem.textContent = formatTime(remainingSeconds);
                countdownTimer = setInterval(() => {
                    remainingSeconds--;
                    countdownElem.textContent = formatTime(remainingSeconds);
                    if (remainingSeconds <= 0) clearInterval(countdownTimer);
                }, 1000);
            }

            function showWarningModal() {
                modalInstance.open();
                startCountdown(Math.floor(warningTime / 1000));
            }

            function scheduleTimers() {
                warningTimer = setTimeout(showWarningModal, sessionTimeOut - warningTime);
                logoutTimer = setTimeout(() => { window.location.href = '/Account/Logout'; }, sessionTimeOut);
            }

            function resetActivityTimers() {
                clearTimeout(warningTimer);
                clearTimeout(logoutTimer);
                scheduleTimers();
            }

            ['keydown', 'click', 'scroll'].forEach(evt => { document.addEventListener(evt, resetActivityTimers); });
            document.getElementById('continue-session').addEventListener('click', () => {
                resetActivityTimers();
                modalInstance.close();
            });

            scheduleTimers();
        });
    </script>


    <script>
document.addEventListener('DOMContentLoaded', function () {
    const idleTimeLimit = 60000;
    const imageInterval = 5000;

    const images = [
       '/images/1.jpeg',
       '/images/2.jpeg',
       '/images/3.jpeg',
       '/images/12.jpeg',
       '/images/5.jpeg',
       '/images/6.jpeg',
       '/images/7.jpeg',
       '/images/8.jpeg',
       '/images/9.jpeg',
       '/images/16.jpeg'
    ];

    let idleTimer = null;
    let imageTimer = null;

    const overlay = document.getElementById('idle-wallpaper');
    const img = document.getElementById('idle-image');

    if (!overlay || !img) {
        console.warn('Idle wallpaper elements not found');
        return;
    }

    function startIdleTimer() {
        clearTimeout(idleTimer);
        idleTimer = setTimeout(showWallpaper, idleTimeLimit);
    }

    function showWallpaper() {
        overlay.style.display = 'block';
        changeImage();
        imageTimer = setInterval(changeImage, imageInterval);
    }

    function hideWallpaper() {
        overlay.style.display = 'none';
        clearInterval(imageTimer);
        startIdleTimer();
    }

    function changeImage() {
        const index = Math.floor(Math.random() * images.length);
        img.src = images[index];
    }

    ['mousemove', 'keydown', 'mousedown', 'scroll', 'touchstart']
        .forEach(evt => {
            document.addEventListener(evt, () => {
                if (overlay.style.display === 'block') {
                    hideWallpaper();
                }
                startIdleTimer();
            });
        });

    startIdleTimer();
});
</script>


    <div id="idle-wallpaper">
    <img id="idle-image" />
</div>

</body>
