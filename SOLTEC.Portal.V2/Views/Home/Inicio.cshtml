@{
    ViewData["Title"] = "Bienvenida";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
    body, html {
        height: 100%;
        margin: 0;
        padding: 0;
        position: relative;
    }

  .watermark {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/images/_simiPet.jpg');
    background-repeat: no-repeat;
        background-size: cover !important;
        background-position: center !important;
    opacity: 0.25; /* ahora un poco más visible */
    z-index: 0;
    pointer-events: none;
}

    .welcome-container {
        text-align: center;
        margin-top: 100px;
        color: #343A40;
        position: relative;
        z-index: 1; /* por encima de la marca de agua */
    }

    .portal-icon {
        font-size: 80px;
        color: #007bff;
        margin-bottom: 10px;
    }
</style>

<!-- Div de marca de agua -->
<div class="watermark"></div>

<div class="welcome-container">
    <i class="material-icons portal-icon">language</i>
    <h1>¡Bienvenido!</h1>
</div>

<script>
    $(document).ready(function () {
        HideLoading();
    });
</script>
