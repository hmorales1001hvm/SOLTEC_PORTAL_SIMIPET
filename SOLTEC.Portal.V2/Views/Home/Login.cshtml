@{
    Layout = null;
    ViewData["Title"] = "Iniciar Sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 15px;
        }

        .card {
            border-radius: 15px;
            overflow: hidden;
        }

        .card-title {
            font-weight: 500;
            color: #1565c0;
        }

        .input-field input {
            color: #000;
        }

        .btn {
            width: 100%;
            border-radius: 8px;
        }

        @@media only screen and (max-width: 600px) {
            .card {
                margin: 0 10px;
            }

            .card-title {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
<body>

    <div class="login-container">
        <!-- ✅ Aquí apuntamos al controlador Account y acción Login -->
        <form method="post" asp-controller="Account" asp-action="Login">
            <div class="card z-depth-3">
                <div class="card-content">
                    <span class="card-title center-align">Iniciar Sesión</span>

                    <div class="input-field">
                        <i class="material-icons prefix">person</i>
                        <input id="usuario" name="usuario" type="text" class="validate" required>
                        <label for="usuario">Usuario</label>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">key</i>
                        <input id="password" name="password" type="password" class="validate" required>
                        <label for="password">Contraseña</label>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <p class="red-text center-align">@ViewBag.Error</p>
                    }
                </div>

                <div class="card-action">
                    <div class="center-align">
                        <button class="btn waves-effect waves-light blue" type="submit" style="min-width: 150px; max-width: 200px;">
                            Ingresar
                            <i class="material-icons right">login</i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

    <script>
        // Actualizar labels de Materialize
        M.updateTextFields();
    </script>
</body>
</html>
